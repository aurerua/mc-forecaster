# Jira credentials (Jira Cloud only)
# Generate your API token at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=you@yourcompany.com
JIRA_TOKEN=your-api-token

# mcf defaults
MCF_DEFAULT_PROJECT=MYPROJECT
# Every issue type your org uses (the full "universe"). Required for Jira runs;
# --exclude-types / --exclude-epic-types subtract from this. If unset, mcf errors
# and lists your project's issue types so you can paste them here.
MCF_JIRA_TYPES=Bug,Story,UX Story,UX Debt,Technical Debt,Task,Spike,Security Vulnerability

# Workday vacation integration (optional — required only when using --workday)
# WD_JSON_LINK is the URL of your Workday RaaS report (JSON format).
# The URL must contain Event_Effective_Date_On_or_After and Event_Effective_Date_On_or_Before
# query params — mcf replaces them with the actual data/forecast date ranges at runtime.
WD_JSON_LINK=https://services1.wd502.myworkday.com/ccx/service/customreport2/yourcompany/ReportName/VacationReport?...&Event_Effective_Date_On_or_Before=2026-01-01&Event_Effective_Date_On_or_After=2026-01-01&format=json
WD_USER=your-workday-integration-user
WD_PASSWORD=your-workday-password

# Comma-separated list of worker names to exclude from vacation counting (e.g. non-engineers)
# WD_EXCLUDE_WORKERS=Alice Smith,Bob Jones
